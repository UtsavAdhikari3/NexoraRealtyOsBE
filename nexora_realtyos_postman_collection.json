            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Sammy\",\n  \"email\": \"sammy@nexora.com\",\n  \"password\": \"Password123\",\n  \"agency_name\": \"Nexora Realty\",\n  \"license_number\": \"NR-001\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Registered or duplicate handled', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([201, 400]);",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    if (json.user && json.user.id) pm.collectionVariables.set('userId', json.user.id);",
                  "    if (json.agency && json.agency.id) pm.collectionVariables.set('agencyId', json.agency.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text",
                "disabled": false
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"sammy@nexora.com\",\n  \"password\": \"Password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login succeeded', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.access) pm.collectionVariables.set('accessToken', json.access);",
                  "if (json.refresh) pm.collectionVariables.set('refreshToken', json.refresh);",
                  "if (json.user && json.user.id) pm.collectionVariables.set('userId', json.user.id);",
                  "if (json.agency && json.agency.id) pm.collectionVariables.set('agencyId', json.agency.id);"
                ]
              }
            }
          ]
        },
